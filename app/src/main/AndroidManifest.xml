<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
         FlipToFocus is 100% offline: NO internet, NO analytics/networking, NO QUERY_ALL_PACKAGES.
         Foreground-app detection uses an AccessibilityService (no UsageStats, no foreground
         service), which is reliable across devices and avoids Android 14 FGS start restrictions.
    -->

    <!-- Draw the offline focus overlay over user-selected distracting apps only. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!--
         Resolve the launchable installed apps for the blocklist screen using
         queryIntentActivities(ACTION_MAIN / CATEGORY_LAUNCHER) - NOT QUERY_ALL_PACKAGES.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".FlipToFocusApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.FlipToFocus"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.FlipToFocus">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
             Foreground-app detector. Protected by BIND_ACCESSIBILITY_SERVICE (held only by the
             system) so no other app can bind to it. exported=true is required for the system to
             bind an accessibility service.
        -->
        <service
            android:name=".service.FocusAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>

</manifest>
