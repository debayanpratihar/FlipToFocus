# Normalize line endings across platforms.
* text=auto eol=lf

# Windows batch files need CRLF.
*.bat text eol=crlf

# The Gradle wrapper launcher must stay LF (it is a POSIX shell script).
gradlew text eol=lf

# Treat binaries as binary (no EOL munging, no diffs).
*.jar binary
*.png binary
*.webp binary
*.jpg binary
*.jpeg binary
*.keystore binary
*.jks binary
